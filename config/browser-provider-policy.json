{
  "schema_version": 2,
  "required_backend": "cloakbrowser",
  "fallback_allowed": false,
  "providers": {
    "webwright": {
      "kind": "high-level-browser-workflow",
      "mcp": false
    },
    "playwright-cli": {
      "kind": "low-level-browser-automation",
      "mcp": false,
      "version": "0.1.17"
    },
    "chrome-devtools-mcp": {
      "kind": "devtools-debugging",
      "mcp": true,
      "version": "1.5.0",
      "transport": [
        "/bin/sh",
        "-c",
        "exec \"$HOME/.local/bin/chrome-devtools-mcp\" --headless --isolated --no-usage-statistics --no-performance-crux"
      ]
    }
  },
  "routing": {
    "long_horizon_web_task": "webwright",
    "screenshots_snapshots_traces": "playwright-cli",
    "console_network_performance_memory_lighthouse": "chrome-devtools-mcp"
  },
  "mimocode_builtin_browser": {
    "enabled": false,
    "reason": "MiMoCode does not replace the approved rldyour browser-provider matrix in this release.",
    "requires_explicit_provider_model_before_enablement": true
  }
}
