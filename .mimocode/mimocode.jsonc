{
  "$schema": "https://mimo.xiaomi.com//config.json",
  "default_agent": "build",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": true,
  "provider": {},
  "disabled_providers": [],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "skill": "allow",
    "bash": "ask",
    "edit": "ask",
    "task": "ask",
    "external_directory": "ask",
    "doom_loop": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "lsp": "allow",
    "question": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "task": "ask",
        "skill": "allow",
        "external_directory": "ask"
      }
    },
    "plan": {
      "permission": {
        "bash": "ask",
        "edit": "deny",
        "task": "ask",
        "skill": "allow",
        "external_directory": "ask"
      }
    },
    "compose": {
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "task": "ask",
        "skill": "allow",
        "external_directory": "ask"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2
  },
  "checkpoint": {
    "reserved": 4096
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "dist/**",
      "node_modules/**",
      ".pytest_cache/**",
      ".serena/cache/**",
      "tasks/**"
    ]
  },
  "instructions": [
    "README.md",
    "MEMORY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "experimental": {
    "maxMode": false
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "serena-agent==1.5.3",
        "--python",
        "3.13",
        "--prerelease",
        "allow",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context=agent",
        "--enable-web-dashboard",
        "False",
        "--open-web-dashboard",
        "False"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp@1.2.0",
        "--headless",
        "--isolated",
        "--no-usage-statistics",
        "--no-performance-crux"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "bunx",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ],
      "enabled": true,
      "environment": {
        "DISABLE_THOUGHT_LOGGING": "true"
      },
      "timeout": 30000
    },
    "shadcn": {
      "type": "local",
      "command": [
        "bunx",
        "shadcn@4.11.0",
        "mcp"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "dart-flutter": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server",
        "--force-roots-fallback"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "@upstash/context7-mcp@3.2.0"
      ],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "timeout": 30000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "context,repos,issues,pull_requests,users"
      },
      "timeout": 15000
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 15000
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "openai-docs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
      "enabled": true,
      "timeout": 15000
    }
  }
}
