{
  "branch": "main",
  "required_status_checks": [
    "Validate",
    "Pytest",
    "Actionlint / actionlint",
    "CodeQL (python) / CodeQL (python)",
    "CodeQL (actions) / CodeQL (actions)",
    "Secret scan / Gitleaks secret scan",
    "Dependency check",
    "Scorecard / OSSF Scorecard analysis",
    "Cross-platform smoke (ubuntu-latest) / smoke (ubuntu-latest)",
    "Cross-platform smoke (macos-latest) / smoke (macos-latest)",
    "Cross-platform smoke (windows-latest) / smoke (windows-latest)"
  ],
  "strict_required_status_checks": true,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "require_linear_history": true,
  "required_pull_request_reviews": {
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_code_owner_review": true
  },
  "enforce_admins": false,
  "notes": [
    "This file documents the desired branch protection state for the public main branch.",
    "Required status checks must use exact job names emitted by .github/workflows/*.yml.",
    "Scorecard runs on push and schedule only; GitHub required checks use the latest default-branch push result."
  ]
}
